{
    "env": {
        "node": true,
        "es2021": true
    },
    "parser": "@typescript-eslint/parser",
    "plugins": [
        "@typescript-eslint" 

    ],
    "extends": [
        "eslint:recommended",
        "plugin:@typescript-eslint/recommended" 

    ],
    "rules": {
        "semi": ["error", "always"],
        "indent": ["error", 3],
        "object-curly-newline": ["error", {
            "multiline": true,
            "minProperties": 1
          }],
          "comma-dangle": ["error", "always"],
          "max-len": ["error", { "code": 80 }]
    }
}
